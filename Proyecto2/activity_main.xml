<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/headerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔐 Control de Acceso Bluetooth"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Escaneo -->
    <Button
        android:id="@+id/scanButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buscar Dispositivos"
        android:layout_marginBottom="8dp" />

    <!-- Dispositivos -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dispositivos Disponibles:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <ListView
        android:id="@+id/devicesListView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="8dp"
        android:background="@color/light_gray"
        android:divider="@color/gray"
        android:dividerHeight="1dp" />

    <!-- Seleccionado -->
    <TextView
        android:id="@+id/selectedDeviceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay dispositivo seleccionado"
        android:textSize="12sp"
        android:textStyle="italic"
        android:layout_marginBottom="8dp" />

    <!-- Conectar -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conectar"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✗ Desconectado"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray"
        android:layout_marginBottom="12dp" />

    <!-- Token -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token de Acceso:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/tokenEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingresa el token"
        android:enabled="false"
        android:inputType="text"
        android:layout_marginBottom="8dp"
        android:padding="8dp" />

    <!-- Solicitar acceso -->
    <Button
        android:id="@+id/requestAccessButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solicitar Acceso"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <!-- Respuesta -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Respuesta:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/responseText"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text=""
        android:textAlignment="center"
        android:textStyle="bold"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:background="@color/light_gray"
        android:padding="8dp" />

    <!-- Desconectar -->
    <Button
        android:id="@+id/disconnectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Desconectar"
        android:enabled="false" />

</LinearLayout>
